generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  EVALUATING
  PROPOSAL_SENT
  NEGOTIATING
  CLOSED_WON
  CLOSED_LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Lead {
  id    String @id @default(cuid())
  // Contact data
  name  String
  email String
  phone String?

  // Property data
  address      String?
  comuna       String?
  propertyType String? // 1BR, 2BR, 3BR, Casa
  surface      Int?
  furnished    Boolean  @default(false)
  parking      Boolean  @default(false)
  amenities    String[]

  // Scoring
  estimatedRevenue   Float?
  investmentRequired Float?
  roiProjected       Float?

  // Pipeline
  status   LeadStatus   @default(NEW)
  priority LeadPriority @default(MEDIUM)
  source   String       @default("web") // evaluacion, contacto, blog, simulador
  notes    String?

  // Follow-up
  nextFollowUp DateTime?
  assignedTo   String?

  // Relations
  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([comuna])
  @@index([createdAt])
}

model Activity {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type   String // note, email, call, status_change, proposal
  title  String
  body   String?

  createdAt DateTime @default(now())

  @@index([leadId])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String
  title       String
  excerpt     String
  content     String
  coverImage  String?
  author      String   @default("MR BnB")
  tags        String[]
  locale      String   @default("es")
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([slug, locale])
  @@index([locale, published])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  type      String   @default("general") // general, evaluacion, corretaje
  createdAt DateTime @default(now())
}
